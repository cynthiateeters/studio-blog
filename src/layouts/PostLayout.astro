---
/**
 * PostLayout.astro - Layout for individual blog posts
 */

import MainLayout from './MainLayout.astro';
import CategoryNav from '../components/CategoryNav.astro';

interface Props {
  title: string;
  subtitle?: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  category: string;
  heroImage?: string;
}

const { title, subtitle, description, pubDate, updatedDate, category, heroImage } = Astro.props;

const pageTitle = `${title} | HyBit Studio`;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const formattedUpdateDate = updatedDate?.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<MainLayout title={pageTitle} description={description}>
  <article class='post'>
    <header class='post-header'>
      <CategoryNav currentCategory={category} />

      <div class='post-meta'>
        <time datetime={pubDate.toISOString()}>{formattedDate}</time>
        {updatedDate && <span class='updated'>Updated: {formattedUpdateDate}</span>}
        <span class='category-badge'>{category}</span>
      </div>

      <h1>{title}</h1>
      {subtitle && <p class='subtitle'>{subtitle}</p>}
    </header>

    {heroImage && <img src={heroImage} alt='' class='hero-image' />}

    <div class='post-content'>
      <slot />
    </div>

    <footer class='post-attribution'>
      <p>— My story. Edited with Claude Code — the same AI I teach with and build with every day.</p>
    </footer>
  </article>
</MainLayout>

<style>
  .post {
    max-width: 80ch;
    margin: 0 auto;
  }

  .post-header {
    margin-bottom: 2rem;
  }

  .post-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
    color: var(--light-brown);
  }

  .updated {
    font-style: italic;
  }

  .category-badge {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    background-color: var(--soft-orange);
    color: var(--dark-brown);
    border-radius: 1rem;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: capitalize;
  }

  h1 {
    font-size: 2.5rem;
    color: var(--dark-brown);
    margin: 0 0 0.5rem 0;
    line-height: 1.2;
  }

  .subtitle {
    font-size: 1.25rem;
    color: var(--medium-brown);
    margin: 0;
    font-style: italic;
  }

  .hero-image {
    width: 100%;
    border-radius: 0.5rem;
    margin-bottom: 2rem;
  }

  .post-content {
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--dark-brown);
  }

  .post-content :global(h2) {
    color: var(--warm-orange);
    margin-top: 2rem;
  }

  .post-content :global(h3) {
    color: var(--medium-brown);
    margin-top: 1.5rem;
  }

  .post-content :global(a) {
    color: var(--teal-darker);
  }

  .post-content :global(code) {
    background-color: var(--peach-background);
    padding: 0.2rem 0.4rem;
    border-radius: 0.25rem;
    font-family: 'Source Code Pro', monospace;
  }

  .post-content :global(pre) {
    background-color: var(--cream-white);
    border: 1px solid var(--soft-orange);
    border-radius: 0.5rem;
    padding: 1rem;
    overflow-x: auto;
  }

  .post-content :global(pre code) {
    background: none;
    padding: 0;
  }

  .post-content :global(blockquote) {
    border-left: 4px solid var(--warm-orange);
    margin: 1.5rem 0;
    padding-left: 1.5rem;
    font-style: italic;
    color: var(--medium-brown);
  }

  .post-attribution {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--soft-orange);
  }

  .post-attribution p {
    margin: 0;
    font-size: 0.9rem;
    font-style: italic;
    color: var(--medium-brown);
  }
</style>
