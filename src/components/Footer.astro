---
/**
 * Footer.astro - Site footer
 */
const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-content">
    <p class="copyright">
      &copy; {currentYear} Cynthia Teeters. HyBit Studio&trade; All rights reserved.
    </p>
    <p class="license-link">
      <a href="/license/">Terms of Use</a>
    </p>
  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--dark-brown);
    color: var(--cream-white);
    padding: 1.5rem 2rem;
    margin-top: auto;
  }

  .footer-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    max-width: 960px;
    margin: 0 auto;
    text-align: center;
  }

  .copyright {
    margin: 0;
    font-size: 0.9rem;
  }

  .license-link {
    margin: 0;
    font-size: 0.8rem;
  }

  .license-link a {
    color: var(--cream-white);
    text-decoration: underline;
    text-underline-offset: 0.15em;
  }

  .license-link a:hover {
    color: var(--soft-orange);
  }
</style>
