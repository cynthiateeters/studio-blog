---
/**
 * Footer.astro - Site footer
 */
const currentYear = new Date().getFullYear();
const repoUrl = "https://github.com/cynthiateeters/studio-blog";
---

<footer class="site-footer">
  <div class="footer-content">
    <nav class="footer-links" aria-label="Footer links">
      <a href={repoUrl} target="_blank" rel="noopener noreferrer" aria-label="View source on GitHub">
        <svg aria-hidden="true" width="20" height="20" viewBox="0 0 16 16" fill="currentColor">
          <path d="M8 0c4.42 0 8 3.58 8 8a8.013 8.013 0 0 1-5.45 7.59c-.4.08-.55-.17-.55-.38 0-.27.01-1.13.01-2.2 0-.75-.25-1.23-.54-1.48 1.78-.2 3.65-.88 3.65-3.95 0-.88-.31-1.59-.82-2.15.08-.2.36-1.02-.08-2.12 0 0-.67-.22-2.2.82-.64-.18-1.32-.27-2-.27-.68 0-1.36.09-2 .27-1.53-1.03-2.2-.82-2.2-.82-.44 1.1-.16 1.92-.08 2.12-.51.56-.82 1.28-.82 2.15 0 3.06 1.86 3.75 3.64 3.95-.23.2-.44.55-.51 1.07-.46.21-1.61.55-2.33-.66-.15-.24-.6-.83-1.23-.82-.67.01-.27.38.01.53.34.19.73.9.82 1.13.16.45.68 1.31 2.69.94 0 .67.01 1.3.01 1.49 0 .21-.15.45-.55.38A7.995 7.995 0 0 1 0 8c0-4.42 3.58-8 8-8Z"/>
        </svg>
        <span>Source</span>
      </a>
      <a href="/rss.xml" aria-label="RSS Feed">
        <svg aria-hidden="true" width="20" height="20" viewBox="0 0 16 16" fill="currentColor">
          <path d="M2.002 2.725a.75.75 0 0 1 .797-.699C8.79 2.42 13.58 7.21 13.974 13.201a.75.75 0 0 1-1.497.098 10.503 10.503 0 0 0-9.776-9.776.75.75 0 0 1-.7-.798ZM2.84 7.05h-.002a7.002 7.002 0 0 1 6.113 6.111.75.75 0 0 1-1.49.178 5.503 5.503 0 0 0-4.8-4.8.75.75 0 0 1 .179-1.489ZM2 13a1 1 0 1 1 2 0 1 1 0 0 1-2 0Z"/>
        </svg>
        <span>RSS</span>
      </a>
    </nav>
    <p class="copyright">
      &copy; {currentYear} Cynthia Teeters. HyBit Studio&trade; All rights reserved.
    </p>
    <p class="license-link">
      <a href="/license/">Terms of Use</a>
    </p>
  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--dark-brown);
    color: var(--cream-white);
    padding: 1.5rem 2rem;
    margin-top: auto;
  }

  .footer-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    max-width: 960px;
    margin: 0 auto;
    text-align: center;
  }

  .copyright {
    margin: 0;
    font-size: 0.9rem;
  }

  .license-link {
    margin: 0;
    font-size: 0.8rem;
  }

  .license-link a {
    color: var(--cream-white);
    text-decoration: underline;
    text-underline-offset: 0.15em;
  }

  .license-link a:hover {
    color: var(--soft-orange);
  }

  .footer-links {
    display: flex;
    gap: 1.5rem;
    margin-bottom: 1rem;
  }

  .footer-links a {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--cream-white);
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.2s ease;
  }

  .footer-links a:hover {
    color: var(--soft-orange);
  }

  .footer-links svg {
    flex-shrink: 0;
  }
</style>
