---
/**
 * DataList.astro - Responsive definition list for key-value pairs
 * Use instead of tables for tool lists, stats, definitions, etc.
 */

interface Props {
  items: Array<{
    term: string;
    definition: string;
  }>;
}

const { items } = Astro.props;
---

<dl class="data-list">
  {items.map(({ term, definition }) => (
    <div class="data-item">
      <dt>{term}</dt>
      <dd>{definition}</dd>
    </div>
  ))}
</dl>

<style>
  .data-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin: 1.5rem 0;
    padding: 0;
  }

  .data-item {
    display: grid;
    grid-template-columns: minmax(120px, auto) 1fr;
    gap: 1rem;
    padding: 0.75rem 1rem;
    background-color: var(--peach-background);
    border-radius: 0.5rem;
    border-left: 3px solid var(--warm-orange);
  }

  dt {
    font-weight: 600;
    color: var(--dark-brown);
  }

  dd {
    margin: 0;
    color: var(--medium-brown);
  }

  @media (max-width: 500px) {
    .data-item {
      grid-template-columns: 1fr;
      gap: 0.25rem;
    }

    dt {
      font-size: 0.9rem;
    }

    dd {
      font-size: 0.95rem;
    }
  }
</style>
