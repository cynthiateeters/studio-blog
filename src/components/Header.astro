---
/**
 * Header.astro - Site header
 */
---

<header class="site-header">
  <a href="/" class="logo-link">
    <div class="site-title">
      <span class="title">HyBit Studio</span>
      <span class="tagline">AI-augmented curriculum for web developers</span>
    </div>
  </a>

  <nav class="main-nav">
    <a href="/">Home</a>
    <a href="/blog/">All Posts</a>
    <a href="/categories/">Categories</a>
  </nav>
</header>

<style>
  .site-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 2rem;
    background-color: var(--cream-white);
    border-bottom: 3px solid var(--soft-orange);
  }

  .logo-link {
    display: flex;
    align-items: center;
    text-decoration: none;
  }

  .site-title {
    display: flex;
    flex-direction: column;
  }

  .title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--dark-brown);
  }

  .tagline {
    font-size: 0.85rem;
    color: var(--light-brown);
  }

  .main-nav {
    display: flex;
    gap: 1.5rem;
  }

  .main-nav a {
    color: var(--medium-brown);
    text-decoration: none;
    font-weight: 600;
    transition: color 0.2s ease;
  }

  .main-nav a:hover {
    color: var(--warm-orange);
  }

  @media (max-width: 600px) {
    .site-header {
      flex-direction: column;
      gap: 1rem;
      text-align: center;
    }

    .tagline {
      display: none;
    }
  }
</style>
