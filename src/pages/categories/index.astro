---
/**
 * categories/index.astro - Categories overview page
 */

import { getCollection } from 'astro:content';
import MainLayout from '../../layouts/MainLayout.astro';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);

const categories = ['tutorials', 'tips', 'stories', 'announcements'];

const categoryCounts = categories.map((cat) => ({
  name: cat,
  count: allPosts.filter((post) => post.data.category === cat).length
}));

const categoryDescriptions: Record<string, string> = {
  tutorials: "Step-by-step guides and lessons on web development topics",
  tips: "Quick insights, shortcuts, and best practices",
  stories: "Classroom experiences and practitioner case studies",
  announcements: "News and updates from HyBit Studio"
};
---

<MainLayout
  title="Categories | HyBit Studio"
  description="Browse blog posts by category."
>
  <h1>Categories</h1>
  <p class="intro">
    Posts are organized into categories to help you find what you're looking for.
  </p>

  <div class="category-grid">
    {categoryCounts.map((cat) => (
      <a href={`/categories/${cat.name}/`} class="category-card">
        <h2>{cat.name}</h2>
        <p class="description">{categoryDescriptions[cat.name]}</p>
        <span class="count">{cat.count} {cat.count === 1 ? 'post' : 'posts'}</span>
      </a>
    ))}
  </div>
</MainLayout>

<style>
  h1 {
    color: var(--dark-brown);
    margin-bottom: 0.5rem;
  }

  .intro {
    color: var(--medium-brown);
    font-size: 1.1rem;
    margin-bottom: 2rem;
  }

  .category-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 1.5rem;
  }

  .category-card {
    display: block;
    background-color: var(--cream-white);
    border: 2px solid var(--soft-orange);
    border-radius: 0.75rem;
    padding: 1.5rem;
    text-decoration: none;
    transition: transform 0.2s ease, border-color 0.2s ease;
  }

  .category-card:hover {
    transform: translateY(-2px);
    border-color: var(--warm-orange);
  }

  .category-card h2 {
    color: var(--warm-orange);
    text-transform: capitalize;
    margin: 0 0 0.5rem 0;
    font-size: 1.5rem;
  }

  .description {
    color: var(--medium-brown);
    font-size: 0.95rem;
    margin: 0 0 1rem 0;
  }

  .count {
    color: var(--light-brown);
    font-size: 0.85rem;
    font-weight: 600;
  }
</style>
